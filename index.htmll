<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Elia Ashia Silvestre</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <h1>Elia Ashia Silvestre</h1>
    <p>Welcome to my personal website</p>
</header>

<section class="about">
    <h2>About Me</h2>
    <img src="images/profile.jpg" alt="My Photo">
    <p>Hello! I'm Elia Ashia Silvestre, 17 years old. I love playing the guitar, arts, gaming, and sports.</p>
</section>

<section class="hobbies">
    <h2>My Hobbies</h2>

    <div class="hobby">
        <img src="images/guitar.jpg">
        <p>Playing Guitar / Band</p>
    </div>

    <div class="hobby">
        <img src="images/drawing.jpg">
        <p>Drawing</p>
    </div>

    <div class="hobby">
        <img src="images/gaming.jpg">
        <p>Gaming</p>
    </div>

    <div class="hobby">
        <img src="images/volleyball.jpg">
        <p>Volleyball</p>
    </div>
</section>

<button onclick="showMessage()">Click Me!</button>

<footer>
    <p>© 2026 Elia Ashia Silvestre</p>
</footer>

<script>
function showMessage() {
    alert("Thanks for visiting my website!");
}
</script>

</body>
</html>
